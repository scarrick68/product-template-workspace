#!/usr/bin/env bash
# Validate workstation prerequisites before running dependency installation workflows.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/ruby_service_dispatch.sh"

require_ruby_or_fail
run_workspace_service_with_ruby \
	"$SCRIPT_DIR" \
	"../lib/workspace/services/preinstall_checks" \
	"Workspace::Services::PreinstallChecks"
