#!/usr/bin/env bash
# Guided installer for missing local development tools and auth configuration.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${SCRIPT_DIR}/lib/ruby_service_dispatch.sh"
source "${SCRIPT_DIR}/lib/ruby_toolchain_bootstrap.sh"
REQUIRED_RUBY="$(read_required_ruby_version "$WORKSPACE_ROOT")"

# Run the Ruby command object once a working Ruby is available.
run_install_local_dev_tools_with_ruby() {
	run_workspace_service_with_ruby \
		"$SCRIPT_DIR" \
		"../lib/workspace/services/install_local_dev_tools" \
		"Workspace::Services::InstallLocalDevTools"
}


# Fast path: run immediately when current PATH Ruby is project-compatible.
if command -v ruby >/dev/null 2>&1 && ruby_compatible_with_required_version "$REQUIRED_RUBY"; then
	run_install_local_dev_tools_with_ruby
	exit $?
fi

if command -v ruby >/dev/null 2>&1; then
	echo "[WARN] Ruby $(ruby -e 'print RUBY_VERSION') is not compatible with required Ruby ${REQUIRED_RUBY}."
	echo "       Bootstrapping a compatible Ruby via mise."
else
	echo "[WARN] Ruby was not found in PATH. Bootstrapping Homebrew + mise + Ruby so install_local_dev_tools can continue."
fi

# Bootstrap Homebrew only after explicit user confirmation.
if ! ensure_brew_in_path; then
	if ! prompt_yes_no "Homebrew is required to bootstrap Ruby and is missing. Install Homebrew now?"; then
		echo "[FAIL] Cannot continue without Ruby. Re-run and allow Homebrew installation, or install Ruby manually first."
		exit 1
	fi

	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	ensure_brew_in_path
fi

# Install mise if missing, then use it to install the required Ruby.
if ! command -v mise >/dev/null 2>&1; then
	if ! prompt_yes_no "mise is required to install Ruby. Install mise now?"; then
		echo "[FAIL] Cannot continue without mise. Re-run and allow mise installation, or install Ruby manually first."
		exit 1
	fi

	echo "[INFO] Installing mise via Homebrew"
	brew install mise
fi

if ! prompt_yes_no "Install Ruby ${REQUIRED_RUBY} with mise now?"; then
	echo "[FAIL] Cannot continue without Ruby ${REQUIRED_RUBY}. Re-run and allow Ruby installation, or install Ruby manually first."
	exit 1
fi

echo "[INFO] Installing Ruby ${REQUIRED_RUBY} via mise"
mise install "ruby@${REQUIRED_RUBY}"
mise use --global "ruby@${REQUIRED_RUBY}"

# Prefer plain `ruby` service dispatch after mise setup by activating mise in this shell.
if command -v mise >/dev/null 2>&1; then
	eval "$(mise activate bash)"
fi

require_compatible_ruby_or_fail "$REQUIRED_RUBY"

# Run setup tools via the freshly provisioned Ruby runtime.
run_workspace_service_with_ruby \
	"$SCRIPT_DIR" \
	"../lib/workspace/services/install_local_dev_tools" \
	"Workspace::Services::InstallLocalDevTools"
