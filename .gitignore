.env
/repos/*
!/repos/.keep
contracts/openapi/*
!/contracts/openapi/.keep

# template workspace local config and state
.workspace/*
!.workspace/.keep

# Infra local config and Terraform/OpenTofu artifacts
config/infra.yml
infra/digitalocean/.terraform/
infra/digitalocean/.terraform.lock.hcl
infra/digitalocean/terraform.tfstate
infra/digitalocean/terraform.tfstate.*
infra/digitalocean/crash.log
infra/digitalocean/crash.*.log
infra/digitalocean/terraform.tfvars
infra/digitalocean/terraform.tfvars.json

# Local test runner output
tmp/test.log

# Terraform plan files, may contain sensitive data, should not be committed
*.tfplan
tfplan