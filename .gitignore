.env
/repos/*
!/repos/.keep
contracts/openapi/*
!/contracts/openapi/.keep

# template workspace local config and state
.workspace/*
!.workspace/.keep

config/workspace.credentials.key
config/workspace.credentials.yml.enc
config/workspace.credentials.backups/

# Terraform working directories
**/.terraform/

# Terraform state
**/*.tfstate
**/*.tfstate.*

# Terraform variable files
**/terraform.tfvars
**/terraform.tfvars.json
**/*.auto.tfvars
**/*.auto.tfvars.json

# Terraform lock files (base template only, should be checked in to live projects)
**/.terraform.lock.hcl

# Terraform plans
**/*.tfplan
**/*tfplan
infra/digitalocean_v2/tfplan

# Terraform crash logs
**/crash.log
**/crash.*.log


# Local test runner output
tmp/test.log

# Ignore creds files for base template
config/workspace.credentials*
