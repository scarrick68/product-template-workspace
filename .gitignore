.env
/repos/*
!/repos/.keep
contracts/openapi/*
!/contracts/openapi/.keep

# template workspace local config and state
.workspace/*
!.workspace/.keep

config/infra.yml

# Terraform working directories
**/.terraform/

# Terraform state
**/*.tfstate
**/*.tfstate.*

# Terraform variable files
**/terraform.tfvars
**/terraform.tfvars.json
**/*.auto.tfvars
**/*.auto.tfvars.json

# Terraform plans
**/*.tfplan

# Terraform crash logs
**/crash.log
**/crash.*.log


# Local test runner output
tmp/test.log